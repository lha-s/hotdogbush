# Frontend (Vite) — exposed to the browser, safe to publish (anon key is public by design).
# For local dev these are printed by `supabase start`.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Token / branding (display only)
VITE_TOKEN_TICKER=HOTDOG
VITE_PUMPFUN_URL=https://pump.fun
